# Postgres connection used by /scripts/probe_*.mjs (n8n metadata DB).
# Format: postgresql://user:password@host:port/db
DATABASE_URL=postgresql://user:password@host:5432/dbname

# n8n base URL (used both server-side by /scripts and client-side via VITE_).
N8N_BASE_URL=https://your-n8n-host.example.com
VITE_N8N_BASE_URL=https://your-n8n-host.example.com

# n8n public REST API key (Settings → API).
# Used by /scripts/patch_*.mjs and /scripts/probe_n8n.mjs.
N8N_API_KEY=replace-with-your-n8n-api-key
